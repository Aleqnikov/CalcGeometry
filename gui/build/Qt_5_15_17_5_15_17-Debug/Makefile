gui.app/Contents/PkgInfo: 
	@test -d gui.app/Contents || mkdir -p gui.app/Contents
	@$(DEL_FILE) gui.app/Contents/PkgInfo
	@echo "APPL????" > gui.app/Contents/PkgInfo
gui.app/Contents/Resources/empty.lproj: 
	@test -d gui.app/Contents/Resources || mkdir -p gui.app/Contents/Resources
	@touch gui.app/Contents/Resources/empty.lproj
	
gui.app/Contents/Info.plist: 
	@test -d gui.app/Contents || mkdir -p gui.app/Contents
	@$(DEL_FILE) gui.app/Contents/Info.plist
	@sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,alq.gui,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},alq.gui,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},10.13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,gui,g" -e "s,@LIBRARY@,gui,g" -e "s,\$${EXECUTABLE_NAME},gui,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" /opt/homebrew/Cellar/qt@5/5.15.17/mkspecs/macx-clang/Info.plist.app >gui.app/Contents/Info.plist

